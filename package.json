{
  "name": "electron-password-manager",
  "version": "1.0.0",
  "description": "Secure local password manager",
  "main": "./out/main/index.js",
  "scripts": {
    "dev": "electron-vite dev",
    "build": "npm run build:icons && electron-vite build && electron-builder --win --x64",
    "build:icons": "node ./scripts/generate-icons.mjs",
    "preview": "electron-vite preview",
    "postinstall": "electron-builder install-app-deps"
  },
  "build": {
    "appId": "com.seuapp.passvault",
    "productName": "PassVault",
    "directories": {
      "output": "./dist"
    },
    "files": [
      "./out/**/*"
    ],
    "win": {
      "target": "nsis",
      "icon": "./resources/PassVault.ico",
      "signingHashAlgorithms": null,
      "sign": null
    },
    "extraResources": [
      { "from": "./resources/PassVault.png", "to": "icon.png" }
    ],
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "installerIcon": "./resources/PassVault.ico",
      "uninstallerIcon": "./resources/PassVault.ico",
      "installerHeaderIcon": "./resources/PassVault.ico"
    }
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "devDependencies": {
    "@electron/rebuild": "^3.6.0",
    "@types/react": "^18.2.48",
    "@types/react-dom": "^18.2.18",
    "@vitejs/plugin-react": "^4.2.1",
    "autoprefixer": "^10.4.17",
    "electron": "^28.0.0",
    "electron-builder": "^24.13.3",
    "electron-reloader": "^1.2.3",
    "electron-vite": "^2.0.0",
    "postcss": "^8.4.33",
    "png-to-ico": "^2.1.8",
    "tailwindcss": "^3.4.1",
    "vite": "^5.0.0"
  },
  "dependencies": {
    "@hookform/resolvers": "^3.3.4",
    "argon2": "^0.44.0",
    "bcryptjs": "^2.4.3",
    "lucide-react": "^0.312.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-hook-form": "^7.49.3",
    "zod": "^3.22.4"
  }
}